{
  "$comment": "Permission boundary for the unattended overnight loop ONLY. Loaded via `claude -p --settings`; your interactive settings (~/.claude/settings.json, .claude/settings.local.json) are untouched. DENY beats ALLOW — the deny list is the real safety boundary. make targets are whitelisted explicitly (no blanket `Bash(make *)`) so a newly-added destructive target is NOT auto-allowed. ADAPT PER REPO: add your project's gate targets to allow, and your destructive/online targets (db/infra/deploy/serve) to deny.",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Skill",
      "Bash(make check)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make typecheck)",
      "Bash(make build)",
      "Bash(make smoke-local)",
      "Bash(make format)",
      "Bash(make lint)",
      "Bash(npx react-scripts test*)",
      "Bash(npm run check-format*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git restore *)",
      "Bash(git checkout -- *)",
      "Bash(git stash*)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(touch scripts/overnight/*)",
      "Bash(cd *)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(rm -rf*)",
      "Bash(sudo *)",
      "Bash(make deploy*)",
      "Bash(make publish*)",
      "Bash(make release*)",
      "Bash(make db-*)",
      "Bash(make infra-*)",
      "Bash(npm run deploy*)",
      "Bash(npm run build*)",
      "Bash(npm start*)",
      "Bash(gh-pages*)",
      "Bash(node fetch.js*)",
      "WebFetch",
      "WebSearch",
      "mcp__github",
      "mcp__playwright"
    ]
  },
  "enabledMcpjsonServers": []
}
